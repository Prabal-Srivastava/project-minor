# Frontend Environment Variables
# Copy this file to .env and configure for your environment

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
# Development: Leave empty to use Vite proxy (recommended)
# Production: Set to your domain (e.g., https://yourdomain.com)
VITE_API_URL=news-prop.ddns.net

# Backend URL for static files (uploads, etc.)
# Development: http://localhost:5000
# Production: Same as VITE_API_URL or leave empty to use same origin
VITE_BACKEND_URL=http://localhost:5000

# ============================================
# STRIPE (Optional - for subscriptions)
# ============================================
# Stripe Publishable Key (safe to expose in frontend)
# Get from https://dashboard.stripe.com/apikeys
# Test key: pk_test_...
# Live key: pk_live_...


# ============================================
# APP METADATA (Optional)
# ============================================
VITE_APP_NAME=News App
VITE_APP_DESCRIPTION=Your daily news source

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable features (set to "false" to disable)
VITE_ENABLE_AI=true
VITE_ENABLE_SUBSCRIPTIONS=true
VITE_ENABLE_COMMENTS=true
VITE_ENABLE_BOOKMARKS=true

# ============================================
# ENVIRONMENT EXAMPLES
# ============================================

# --- DEVELOPMENT (Local) ---
# VITE_API_URL=
# VITE_BACKEND_URL=http://localhost:5000
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- PRODUCTION (Same Domain) ---
# VITE_API_URL=https://yourdomain.com
# VITE_BACKEND_URL=https://yourdomain.com
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- PRODUCTION (Separate API Domain) ---
# VITE_API_URL=https://api.yourdomain.com
# VITE_BACKEND_URL=https://api.yourdomain.com
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ============================================
# NOTES
# ============================================
#
# DEVELOPMENT:
# - Leave VITE_API_URL empty to use Vite proxy
# - Vite proxy forwards /api/* to http://localhost:5000
# - Set VITE_BACKEND_URL=http://localhost:5000 for uploads
#
# PRODUCTION:
# - Set VITE_API_URL to your production domain
# - Backend and frontend on same domain: VITE_API_URL=https://yourdomain.com
# - Backend on subdomain: VITE_API_URL=https://api.yourdomain.com
# - Use production Stripe key (pk_live_*)
#
# BUILDING:
# - Run: npm run build
# - Environment variables are embedded at build time
# - Rebuild after changing .env file
#

